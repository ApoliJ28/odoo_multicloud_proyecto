<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Lista -->
    <record id="view_multicloud_node_tree" model="ir.ui.view">
        <field name="name">multicloud.node.tree</field>
        <field name="model">multicloud.node</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="cloud_provider"/>
                <field name="ip_address"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_multicloud_node" model="ir.actions.act_window">
        <field name="name">Nodos Multicloud</field>
        <field name="res_model">multicloud.node</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menús -->
    <menuitem id="menu_multicloud_root" name="Multicloud Infra" sequence="10"/>
    <menuitem id="menu_multicloud_nodes" name="Nodos" parent="menu_multicloud_root" action="action_multicloud_node"/>
</odoo>